<IfModule mod_rewrite.c>
    RewriteEngine On

    # Stop processing if request is already in public directory
    RewriteCond %{REQUEST_URI} !^/public/

    # Rewrite all requests to the public directory
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# Disable directory browsing
Options -Indexes

# Protect sensitive files
<FilesMatch "^\.env|composer\.json|package\.json|artisan">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
